{
  "name": "clommit",
  "version": "0.1.0",
  "description": "AI commit messages powered by Claude. Cost-transparent, lightweight, zero bloat.",
  "author": "Muhammad Saeed",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/muhammadcaeed/clommit.git"
  },
