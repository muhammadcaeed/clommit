  "type": "module",
  "engines": {
    "node": ">=18.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "dependencies": {
    "chalk": "5.4.1",
    "commander": "13.1.0"
  },
  "devDependencies": {
    "@types/node": "22.13.9",
    "tsup": "8.4.0",
    "typescript": "5.7.3",
    "vitest": "^4.0.18"
  }
